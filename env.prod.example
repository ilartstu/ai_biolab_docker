POSTGRES_DB=ai_biolab
POSTGRES_USER=ai_biolab

# Используй hex-пароль: он безопасно вставляется в DATABASE_URL без URL-кодирования.
# Сгенерировать: openssl rand -hex 32
POSTGRES_PASSWORD=REPLACE_WITH_HEX_PASSWORD

# В коде запросы уже начинаются с /api, поэтому базовый адрес — корень домена.
REACT_APP_API_URL=/

CGAN_N_TRAJECTORIES=100

AGENT_START_DAY=2020-03-12
AGENT_RAND_SEED=1
AGENT_MODEL_VERSION=covasim-3.1.8-adapter-1
AGENT_MAX_INTERVENTIONS=50

MOCK_SLEEP_SECONDS=0
MAX_PARALLEL_RUNS=2
MAX_QUEUE_SIZE=10
