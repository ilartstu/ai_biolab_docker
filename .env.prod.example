# ─── Прод-окружение (Фаза 1: запуск по IP, HTTP) ───
# Скопируй этот файл в .env.prod НА СЕРВЕРЕ и заполни значения.
# .env.prod в git НЕ коммитится (см. .gitignore).
#   cp .env.prod.example .env.prod && nano .env.prod

# ── База данных ──
POSTGRES_DB=ai_biolab
POSTGRES_USER=ai_biolab
# ОБЯЗАТЕЛЬНО смени на длинный случайный пароль, например: openssl rand -base64 24
POSTGRES_PASSWORD=CHANGE_ME_use_a_long_random_password

# ── Публичный порт nginx ──
# Фаза 1: 80 (HTTP). Фаза 2 добавим 443 (HTTPS) при подключении домена.
HTTP_PORT=80

# ── Куки сессии ──
# Фаза 1 (HTTP): false. После подключения HTTPS (Фаза 2) поставить true.
SECURE_COOKIE=false

# ── CORS ──
# Пусто для same-origin (фронт и API на одном домене/IP — CORS не нужен).
# Фаза 2: CORS_ORIGINS=https://ai-biolab.ru,https://www.ai-biolab.ru
CORS_ORIGINS=

# ── Параметры моделирования ──
CGAN_N_TRAJECTORIES=100
MOCK_SLEEP_SECONDS=3
MAX_PARALLEL_RUNS=2
MAX_QUEUE_SIZE=10
